# Grid Survival - Environment Configuration Example
# Copy this file to .env in the repo root and fill in values for your deployment

# VPS Control Plane (HTTP API for lobby/matchmaking)
# This is where the client connects to join lobbies and find matches
GRID_SURVIVAL_ONLINE_API=http://38.242.246.126:8010

# API Key for authentication with the control plane
# Must match the key in backend/.env on the VPS
GRID_SURVIVAL_ONLINE_API_KEY=a2fcb46811703d361f5074c6c86f01d6a241f30960b4176d4d924b90763822f2

# Optional: LAN Discovery (used for LAN lobbies, not needed for internet play)
# LAN_SERVER_HOST=192.168.1.100
# LAN_SERVER_PORT=9999
