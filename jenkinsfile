pipeline {
    // No pipeline-wide agent: PyInstaller can't cross-compile a Windows .exe
    // from Linux, and Inno Setup (ISCC.exe) is Windows-only, so the build has
    // to run on a Windows agent while deployment targets the Ubuntu VPS
    // hosting /var/www/. Each stage below picks its own agent instead.
    //
    // Prerequisite: register a Windows Jenkins agent (labeled "windows") on
    // the machine that has Python, the packages in requirements.txt,
    // PyInstaller, and Inno Setup 6 installed.
    //
    // Prerequisite (one-time, on the Ubuntu VPS): this site is served by
    // nginx, which ignores .htaccess entirely, so add this to the site's
    // server block (e.g. /etc/nginx/sites-available/gridsurvival) once, then
    // `sudo nginx -t && sudo systemctl reload nginx` -- the pipeline does not
    // touch nginx config on every deploy:
    //
    //   server {
    //       ...
    //       location ~* \.(html|htm|js|json)$ {
    //           add_header Cache-Control "no-cache, no-store, must-revalidate" always;
    //           add_header Pragma "no-cache" always;
    //           add_header Expires "0" always;
    //       }
    //   }
    agent none
    options {
        skipDefaultCheckout(true)
        disableConcurrentBuilds()
        timeout(time: 50, unit: 'MINUTES')
    }

    // Webhook triggers
    triggers {
        githubPush()
    }

    stages {
        stage('Checkout Main Branch') {
            // No deleteDir()/fresh checkout here on purpose: this repo is
            // large enough (binary game assets across many commits) that a
            // full re-clone every build was timing out / getting killed
            // mid-transfer. Instead, reuse whatever repo already sits in the
            // workspace and just fetch+reset to the latest main -- for the
            // very first run, seed the workspace once by copying an already-
            // cloned checkout of this repo into the Windows agent's
            // workspace directory yourself (see the customWorkspace/remote
            // root dir configured on the "windows" node) so this stage finds
            // an existing .git to update instead of cloning from scratch.
            agent { label 'windows' }
            steps {
                bat '''
                    rem The Jenkins Windows agent runs as a service under
                    rem NT AUTHORITY\\SYSTEM, but the workspace folder is owned
                    rem by the interactive user account -- git refuses to touch
                    rem a repo it doesn't consider "owned" by the current user
                    rem unless told to trust it. This is a dedicated CI agent,
                    rem so blanket-trusting is fine.
                    git config --global --add safe.directory "*"
                    if not exist .git (
                        echo === No existing repo in workspace, cloning once ===
                        git clone --depth 1 --branch main https://github.com/Kynmmarshall/Grid_Survival.git .
                    ) else (
                        echo === Existing repo found, updating to latest main ===
                        git remote set-url origin https://github.com/Kynmmarshall/Grid_Survival.git
                        git fetch --depth 1 origin main
                        git checkout -B main origin/main
                        git reset --hard origin/main
                    )
                    echo Local HEAD:
                    git rev-parse --short HEAD
                    echo Last commit:
                    git log -1 --pretty=oneline
                '''
            }
        }

        stage('Install Python Dependencies') {
            agent { label 'windows' }
            steps {
                bat '''
                    if exist venv\\Scripts\\python.exe (
                        echo === Reusing existing virtual environment ===
                    ) else (
                        echo === Creating virtual environment (first run, or previously deleted) ===
                        if exist venv rmdir /s /q venv
                        python -m venv venv
                    )
                    echo === Installing/Updating Python Dependencies (in venv) ===
                    venv\\Scripts\\python.exe -m pip install --upgrade pip
                    venv\\Scripts\\python.exe -m pip install -r requirements.txt
                    venv\\Scripts\\python.exe -m pip install pyinstaller opencv-python
                '''
            }
        }

        stage('Build Game (PyInstaller)') {
            agent { label 'windows' }
            steps {
                bat '''
                    echo === Cleaning previous build artifacts ===
                    if exist build rmdir /s /q build
                    if exist dist rmdir /s /q dist
                    if exist Output rmdir /s /q Output
                    echo === Building Release Version (--onedir) ===
                    venv\\Scripts\\python.exe -m PyInstaller --onedir --noconsole --icon=icon.ico --add-data "assets;assets" --add-data "tiles;tiles" --hidden-import=cv2 --hidden-import=numpy main.py
                '''
            }
        }

        stage('Build Installer (Inno Setup)') {
            agent { label 'windows' }
            steps {
                bat '''
                    echo === Building Installer ===
                    rem setupScript.iss expects dist\\main\\Grid Survival.exe; PyInstaller
                    rem names the onedir build's exe after the entry script (main.exe).
                    copy /Y "dist\\main\\main.exe" "dist\\main\\Grid Survival.exe"
                    "C:\\Program Files (x86)\\Inno Setup 6\\ISCC.exe" setupScript.iss
                '''
            }
        }

        stage('Deploy Installer') {
            // Uploads directly from the Windows agent to the Ubuntu VPS via
            // scp (SSH key auth, see jenkins-agent's C:\jenkins-agent\.ssh\),
            // instead of Jenkins' stash/unstash -- stash is an opaque zip
            // copy through the controller with no visibility into transfer
            // progress. Doing our own scp + polling the remote file's
            // growing size lets us log real MB-uploaded/remaining progress.
            //
            // GridSurvivalWebsite is its own hand-maintained Node.js/PM2 site
            // (its own git repo, server.js, update.sh, real pages) -- this
            // pipeline must NOT touch index.html/style.css/server.js/etc.
            // Its only job here is to drop the freshly built installer into
            // the site's existing assets/download/ folder.
            agent { label 'windows' }
            when {
                expression { currentBuild.result != 'FAILURE' }
            }
            steps {
                powershell '''
                    # Deliberately not "Stop": PowerShell 5.1 treats ANY
                    # stderr line from a native command (ssh/scp) as a
                    # terminating error under that preference, even benign
                    # ones like ssh's "Permanently added ... known hosts"
                    # notice -- real failures are still caught explicitly
                    # below via $LASTEXITCODE/job-state checks.
                    $ErrorActionPreference = "Continue"
                    $sshKey = "C:\\jenkins-agent\\.ssh\\id_ed25519"
                    $remote = "root@38.242.246.126"
                    $remoteDir = "/var/www/GridSurvivalWebsite/assets/download"
                    $remoteTmp = "$remoteDir/Grid-Survival.exe.uploading"
                    $remoteFinal = "$remoteDir/Grid-Survival.exe"
                    $sshOpts = @("-i", $sshKey, "-o", "StrictHostKeyChecking=accept-new")

                    $installer = Get-ChildItem -Path "Output" -Filter "*.exe" | Select-Object -First 1
                    if (-not $installer) { throw "No installer .exe found in Output/" }

                    $totalBytes = $installer.Length
                    $totalMB = [math]::Round($totalBytes / 1MB, 2)
                    Write-Output "=== Uploading $($installer.Name) ($totalMB MB) to $remote ==="

                    & ssh @sshOpts $remote "mkdir -p '$remoteDir'"
                    if ($LASTEXITCODE -ne 0) { throw "Failed to prepare remote download directory" }

                    # Run scp in a background job rather than Start-Process:
                    # Start-Process's .ExitCode came back unreliable (null)
                    # in this service-account context even after
                    # WaitForExit(), repeatedly failing builds whose uploads
                    # had actually fully succeeded. Start-Job's -ArgumentList
                    # also passes the installer's path as a real string
                    # (no command-line re-quoting), sidestepping the earlier
                    # space-in-filename issue too.
                    $job = Start-Job -ScriptBlock {
                        param($sshKeyArg, $remoteArg, $localPath, $remoteDest)
                        & scp -i $sshKeyArg -o StrictHostKeyChecking=accept-new $localPath "${remoteArg}:${remoteDest}"
                        if ($LASTEXITCODE -ne 0) { throw "scp exited with code $LASTEXITCODE" }
                    } -ArgumentList $sshKey, $remote, $installer.FullName, $remoteTmp

                    while ($job.State -eq 'Running') {
                        # 15s (not 3s): polling opens a brand-new SSH
                        # connection each time, and hammering that every few
                        # seconds for a multi-minute transfer previously
                        # tripped the VPS's SSH connection rate-limiting
                        # (common hardening, e.g. "ufw limit ssh"), which then
                        # crashed the whole build on a null-handling bug below.
                        Start-Sleep -Seconds 15
                        try {
                            $statCmd = "stat -c%s '$remoteTmp' 2>/dev/null || echo 0"
                            $remoteSizeRaw = & ssh @sshOpts $remote $statCmd
                            $remoteSize = 0L
                            $lastLine = $remoteSizeRaw | Select-Object -Last 1
                            if ($lastLine) {
                                [int64]::TryParse($lastLine.ToString().Trim(), [ref]$remoteSize) | Out-Null
                            }
                            $remoteMB = [math]::Round($remoteSize / 1MB, 2)
                            $remainMB = [math]::Round([math]::Max(0, $totalBytes - $remoteSize) / 1MB, 2)
                            $pct = if ($totalBytes -gt 0) { [math]::Round(($remoteSize / $totalBytes) * 100, 1) } else { 100 }
                            Write-Output "Uploaded: $remoteMB MB / $totalMB MB ($pct%) -- Remaining: $remainMB MB"
                        } catch {
                            # A transient polling hiccup (or rate-limit) isn't
                            # fatal -- the actual scp transfer is a separate,
                            # already-established connection and may well
                            # still be running fine. Just skip this update.
                            Write-Output "(progress check skipped: $($_.Exception.Message))"
                        }
                    }

                    Wait-Job $job | Out-Null
                    $jobOutput = Receive-Job $job -ErrorAction SilentlyContinue 2>&1
                    $jobState = $job.State
                    Remove-Job $job -Force
                    if ($jobOutput) { $jobOutput | ForEach-Object { Write-Output $_ } }
                    if ($jobState -ne 'Completed') { throw "scp job did not complete successfully (state: $jobState)" }

                    Write-Output "=== Upload finished, finalizing on remote ==="
                    $finalizeCmd = "mv '$remoteTmp' '$remoteFinal' && ls -lh '$remoteFinal'"
                    & ssh @sshOpts $remote $finalizeCmd
                    if ($LASTEXITCODE -ne 0) { throw "Failed to finalize remote file" }
                    Write-Output "Deployed to ${remote}:${remoteFinal}"
                '''
            }
        }
    }

    post {
        always {
            script {
                node('windows') {
                    archiveArtifacts artifacts: 'Output/*.exe', fingerprint: true, allowEmptyArchive: true
                }
            }
        }
        success {
            echo '🎉 Build successful! New version deployed to website.'
            script {
                node('!windows') {
                    sh '''
                        echo "Build ${BUILD_NUMBER} completed successfully!\\nBuild URL: ${BUILD_URL}" | mail -s "SUCCESS: Grid Survival Build ${BUILD_NUMBER}" kynmmarshall@gmail.com || echo "Email failed, but build succeeded"
                    '''
                }
            }
        }
        failure {
            echo '❌ Build failed! Check the logs for errors.'
            script {
                node('!windows') {
                    sh '''
                        echo "Build ${BUILD_NUMBER} failed. Check: ${BUILD_URL}" | mail -s "FAILURE: Grid Survival Build ${BUILD_NUMBER}" kynmmarshall@gmail.com || echo "Email failed"
                    '''
                }
            }
        }
    }
}
